# --- App database (Railway Postgres plugin or Supabase) ---
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Sell.do reporting DBs (read-only) ---
SELLDO_DB_URL_RON=postgresql://...
SELLDO_DB_URL_ELEMENTS=postgresql://...

# --- Meta access tokens ---
META_TOKEN_RON=EAAS...
META_TOKEN_ELEMENTS=EAAV...

# --- WasenderAPI (legacy, being replaced by Wati) ---
WASENDER_API_KEY=...
WASENDER_SESSION_ID=67860
# Set this same value in the Wasender dashboard webhook secret field (optional)
WASENDER_WEBHOOK_SECRET=

# --- Wati (official WhatsApp Cloud API) ---
# Base URL from Wati dashboard -> API Docs (no trailing slash)
WATI_BASE=https://live-server-12345.wati.io
# Access token from Wati -> API Docs. Paste WITHOUT "Bearer ".
WATI_TOKEN=
# Optional shared secret to verify inbound webhooks (set same value in Wati)
WATI_WEBHOOK_SECRET=
# Approved template names (only set if they differ from these defaults)
WATI_TPL_M1_RON=gtb_m1_ron
WATI_TPL_M1_ELEMENTS=gtb_m1_elements
WATI_TPL_M2=gtb_m2_followup
WATI_TPL_M3=gtb_m3_reminder
WATI_TPL_M3_GENERIC=gtb_m3_generic
WATI_TPL_ACK=gtb_ack

# --- Event config ---
EVENT_NAME=GTB Carnival
EVENT_VENUE=GTB Lounge, EA Mall, Chennai
EVENT_MAPS_LINK=https://maps.app.goo.gl/MU1rPtQ6qLFC74jy8
EVENT_TIMING=All day (mall hours)
EVENT_DATES=2026-07-10,2026-07-11,2026-07-12

# --- Safety ---
MAX_SENDS_PER_HOUR=30
GLOBAL_PAUSE=false

# --- Dashboard auth (basic) ---
DASH_USER=admin
DASH_PASS=change-me

# --- Polling intervals (minutes) ---
SELLDO_POLL_MIN=10
META_ADS_POLL_MIN=30
SEQUENCER_TICK_MIN=5
